{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": [
    "cli/**/*.ts",
    "core/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests",
    "archive",
    "docs",
    "skills",
    "agents",
    "packs",
    "templates"
  ]
}
