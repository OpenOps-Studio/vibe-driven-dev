{
  "name": "vibe-driven-dev",
  "version": "0.1.1",
  "description": "The missing pre-execution layer for AI coding agents. Vibe Driven Dev turns messy ideas into structured plans, stack decisions, AI model choices, bootstrap files, and handoff-ready workflows.",
  "type": "module",
  "bin": {
    "vibe-driven-dev": "dist/cli/src/index.js"
  },
  "main": "dist/cli/src/index.js",
  "files": [
    "agents",
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenOps-Studio/vibe-driven-dev.git"
  },
  "homepage": "https://github.com/OpenOps-Studio/vibe-driven-dev#readme",
  "bugs": {
    "url": "https://github.com/OpenOps-Studio/vibe-driven-dev/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx cli/src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist",
    "start": "node dist/cli/src/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "vibe-coding",
    "ai-agents",
    "coding-agents",
    "claude-code",
    "codex",
    "cursor",
    "developer-tools",
    "gemini-cli",
    "llm",
    "mcp",
    "open-source",
    "opencode",
    "orchestration",
    "productivity",
    "scaffolding",
    "spec-driven-development",
    "windsurf"
  ],
  "author": "Mamdouh Aboammar",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
