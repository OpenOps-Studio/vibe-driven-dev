{
    "rules": {
        "ARCH-DEP-01": {
            "description": "Components cannot import from Pages",
            "severity": "error",
            "glob": "src/components/**/*.{ts,tsx}",
            "forbidden_patterns": [
                {
                    "regex": "from\\s+['\"].*\\/pages\\/.*['\"]",
                    "message": "Component violates unidirectional dependency: Cannot import from 'pages'"
                },
                {
                    "regex": "from\\s+['\"]@\\/pages\\/.*['\"]",
                    "message": "Component violates unidirectional dependency: Cannot import from '@/pages'"
                }
            ]
        },
        "STYL-TW-01": {
            "description": "No hardcoded hex values in TSX (Use tokens)",
            "severity": "warning",
            "glob": "src/**/*.{tsx,jsx}",
            "forbidden_patterns": [
                {
                    "regex": "className=.*#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})",
                    "message": "Hardcoded hex color found in className. Use strict design tokens (e.g., bg-primary, text-accent)."
                },
                {
                    "regex": "style=\\{.*#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}).*\\}",
                    "message": "Hardcoded hex color found in inline style. Use strict design tokens."
                }
            ]
        },
        "SEC-SECRETS-03": {
            "description": "No hardcoded secrets or API keys",
            "severity": "critical",
            "glob": "**/*.{ts,tsx,js,json}",
            "forbidden_patterns": [
                {
                    "regex": "(?i)(api_key|secret|token)\\s*[:=]\\s*['\"][A-Za-z0-9_-]{20,}['\"]",
                    "message": "Potential hardcoded secret detected. Use process.env or a secure vault."
                }
            ]
        },
        "ICON-REACT-01": {
            "description": "No direct react-icons usage (Use designSystem wrapper)",
            "severity": "error",
            "glob": "src/features/**/*.{ts,tsx}",
            "forbidden_patterns": [
                {
                    "regex": "from\\s+['\"]react-icons.*['\"]",
                    "message": "Direct import of react-icons allowed only in @/designSystem/icons."
                }
            ]
        },
        "PATH-ALIAS-01": {
            "description": "Use @ alias for imports",
            "severity": "error",
            "glob": "src/**/*.{ts,tsx}",
            "forbidden_patterns": [
                {
                    "regex": "from\\s+['\"]\\.\\.\\/\\.\\.\\/.*['\"]",
                    "message": "Deep relative import detected. Use '@/' alias."
                }
            ]
        },
        "A11Y-SEMANTIC-01": {
            "description": "Avoid non-semantic interactive elements",
            "severity": "warning",
            "glob": "src/**/*.{tsx,jsx}",
            "forbidden_patterns": [
                {
                    "regex": "<div[^>]*onClick",
                    "message": "Clickable <div> detected. Use <button> or add role='button' with key handlers."
                }
            ]
        },
        "MOD-SIZE-02": {
            "description": "Component size limit",
            "severity": "warning",
            "check_type": "line_count",
            "glob": "src/components/**/*.{tsx,jsx}",
            "max_lines": 250,
            "message": "Component exceeds 250 lines. Decompose it."
        }
    }
}