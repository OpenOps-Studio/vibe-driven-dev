{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "masterRuleSet": "{{PROJECT_NAME}} Master Coding Rules",
  "version": "2.0.1",</search>
</search_and_replace>
    "lastUpdated": "2025-11-04",</search>
</search_and_replace>
  "description": "Unified comprehensive rules file for {{PROJECT_NAME}} platform - combines all architectural, programming, and security rules",
  "philosophy": {
    "core": "Consistency beats creativity at scale",
    "principles": [
      "Rules are mandatory, not optional",
      "Any violation = automatic PR rejection",
      "Untested code = broken code",
      "Security is not optional",
      "Private by default"
    ]
  },
  "enforcement": {
    "policy": "All code must validate against these rules before merge",
    "verification": [
      "TypeScript Compiler (tsc --noEmit)",
      "ESLint with custom rules",
      "Vitest (80% coverage minimum)",
      "Security scans (Codacy)",
      "Dependency audits",
      "Performance checks"
    ],
    "actions": {
      "violation": "Auto-reject PR/commit",
      "escalation": "Flag to AI Staff Engineer"
    }
  },
  "rules": {
    "architecture": {
      "category": "Architectural Structure",
      "priority": "critical",
      "rules": [
        {
          "id": "ARCH-DEP-01",
          "name": "Unidirectional Dependencies",
          "description": "Unidirectional flow from top to bottom only",
          "flow": "Pages → Components → Hooks/Utils → Types/Constants",
          "forbidden": [
            "Components importing Pages",
            "Circular imports",
            "Cross-imports between Hooks/Engine"
          ],
          "solutions": [
            "Move shared logic to utils/types/constants",
            "Lift state up via props",
            "Create new foundation file in types/"
          ],
          "verification": "npm run debug:deps",
          "severity": "blocking"
        },
        {
          "id": "ARCH-DEP-02",
          "name": "Pages Import Rules",
          "canImportFrom": [
            "components",
            "hooks",
            "engine",
            "utils",
            "types",
            "constants"
          ],
          "cannotImportFrom": [
            "pages"
          ],
          "rationale": "Pages are top-level entry points"
        },
        {
          "id": "ARCH-DEP-03",
          "name": "Components Import Rules",
          "canImportFrom": [
            "components (UI primitives only)",
            "hooks",
            "engine",
            "utils",
            "types",
            "constants"
          ],
          "cannotImportFrom": [
            "pages"
          ],
          "rationale": "Components are reusable UI building blocks"
        },
        {
          "id": "ARCH-DEP-04",
          "name": "Types & Constants Rules",
          "canImportFrom": [
            "types (self-contained only)"
          ],
          "cannotImportFrom": [
            "pages",
            "components",
            "engine",
            "hooks",
            "utils"
          ],
          "rationale": "Types and constants are the absolute foundation"
        }
      ]
    },
    "componentModularity": {
      "category": "Component Structure",
      "priority": "critical",
      "rules": [
        {
          "id": "MOD-SRP-01",
          "name": "Single Responsibility Principle",
          "description": "Each Component does only one thing",
          "guidelines": [
            "Separate UI presentation from state logic",
            "Separate data fetching from rendering",
            "Component name must clearly describe its function"
          ],
          "examples": {
            "good": "UserProfileCard, PostComposer, CommentList",
            "bad": "UserStuff, DataThing, MainComponent"
          }
        },
        {
          "id": "MOD-SIZE-02",
          "name": "Component Size Limits",
          "metrics": {
            "softLimit": {
              "lines": 150,
              "action": "Review required"
            },
            "hardLimit": {
              "lines": 250,
              "action": "Build failure"
            },
            "useEffectLimit": {
              "count": 3,
              "action": "Refactor required"
            }
          },
          "severity": "blocking"
        },
        {
          "id": "MOD-DECOMP-03",
          "name": "Component Decomposition Pattern",
          "structure": {
            "folder": "ComponentName/",
            "files": [
              "index.tsx (Orchestrator)",
              "ComponentHeader.tsx (Sub-component)",
              "ComponentContent.tsx (Sub-component)",
              "ComponentFooter.tsx (Sub-component)"
            ]
          },
          "example": {
            "bad": "Single 300-line component",
            "good": "Parent component orchestrating 4 focused sub-components"
          }
        },
        {
          "id": "MOD-HOOKS-04",
          "name": "Logic Abstraction with Custom Hooks",
          "description": "Extract complex logic to custom hooks",
          "guidelines": [
            "Heavy useState/useEffect logic → custom hook",
            "Keep component body focused on JSX rendering",
            "Reusable logic must be in hooks/"
          ],
          "examples": [
            "useTheme",
            "useExportHistory",
            "usePosts"
          ]
        }
      ]
    },
    "styling": {
      "category": "Design and Themes",
      "priority": "high",
      "rules": [
        {
          "id": "STYL-TW-01",
          "name": "Tailwind CSS v4 Only",
          "description": "All design must use Tailwind utilities only",
          "config": {
            "type": "CSS-based (@theme directive)",
            "location": "index.css",
            "approach": "Design tokens via CSS variables"
          },
          "forbidden": [
            "Custom CSS files",
            "Inline styles (except dynamic values)",
            "Other CSS frameworks",
            "Tailwind JS config for tokens"
          ]
        },
        {
          "id": "STYL-TOKENS-02",
          "name": "Design Tokens Enforcement",
          "description": "All colors and spacing from design tokens",
          "tokens": {
            "colors": "var({{BG_COLOR}}), var({{ACCENT_COLOR}}), var({{TEXT_COLOR}})",
            "radius": "var({{CARD_RADIUS}}), var({{BUTTON_RADIUS}})",
            "animations": "--animate-fade-in-up, --animate-slide-up"
          },
          "forbidden": [
            "Hardcoded hex values: #E3348B",
            "Arbitrary values: text-[#123456]",
            "Magic numbers: p-[23px]"
          ],
          "correct": [
            "text-{{PROJECT_NAME}}-accent",
            "bg-{{PROJECT_NAME}}-bg",
            "p-4 (from scale)"
          ],
          "severity": "blocking"
        },
        {
          "id": "STYL-RESP-03",
          "name": "Responsive Design",
          "breakpoints": {
            "mobile": "< 768px",
            "tablet": "768px - 1024px",
            "desktop": "> 1024px"
          },
          "approach": "Mobile-first with Tailwind breakpoints (md:, lg:, xl:)"
        }
      ]
    },
    "motionSystem": {
      "category": "Motion and Animation System",
      "priority": "high",
      "rules": [
        {
          "id": "MOTION-LIB-01",
          "name": "Framer Motion Only",
          "library": "Framer Motion",
          "easing": "cubic-bezier(0.22, 1, 0.36, 1)",
          "philosophy": [
            "Calm",
            "Fluid",
            "Purposeful",
            "Responsive"
          ]
        },
        {
          "id": "MOTION-TIMING-02",
          "name": "Timing Scale",
          "scale": {
            "micro": "100ms (hover effects)",
            "short": "180ms (quick transitions)",
            "medium": "300ms (modals, cards)",
            "long": "500ms (complex animations)",
            "xlong": "800ms (page transitions)"
          }
        },
        {
          "id": "MOTION-TOKENS-03",
          "name": "Motion Tokens",
          "tokens": {
            "fade_in": {
              "opacity": [
                0,
                1
              ],
              "duration": "medium"
            },
            "fade_out": {
              "opacity": [
                1,
                0
              ],
              "duration": "short"
            },
            "slide_up": {
              "y": [
                40,
                0
              ],
              "opacity": [
                0,
                1
              ],
              "duration": "medium"
            },
            "slide_down": {
              "y": [
                -30,
                0
              ],
              "opacity": [
                0,
                1
              ],
              "duration": "medium"
            },
            "scale_in": {
              "scale": [
                0.95,
                1
              ],
              "opacity": [
                0,
                1
              ],
              "duration": "medium"
            },
            "scale_out": {
              "scale": [
                1,
                0.9
              ],
              "opacity": [
                1,
                0
              ],
              "duration": "short"
            },
            "hover_lift": {
              "scale": [
                1,
                1.03
              ],
              "duration": "micro"
            },
            "press_tap": {
              "scale": [
                1,
                0.97
              ],
              "duration": "micro"
            }
          }
        },
        {
          "id": "MOTION-A11Y-04",
          "name": "Accessibility Support",
          "prefers_reduced_motion": true,
          "fallback": "Disable transforms and opacity animations when user prefers reduced motion"
        },
        {
          "id": "MOTION-CONTEXTS-05",
          "name": "Context-Specific Animations",
          "contexts": {
            "modals": {
              "entry": "scale_in",
              "exit": "fade_out"
            },
            "cards": {
              "hover": "hover_lift",
              "entry": "fade_in"
            },
            "buttons": {
              "hover": "scale_in",
              "press": "press_tap"
            },
            "lists": {
              "item_entry": "slide_up",
              "stagger": "50ms"
            },
            "tooltips": {
              "entry": "slide_up",
              "delay": "120ms"
            },
            "dropdowns": {
              "entry": "scale_in",
              "origin": "top-right"
            },
            "alerts": {
              "entry": "slide_down",
              "exit": "fade_out"
            }
          }
        }
      ]
    },
    "icons": {
      "category": "Icon System",
      "priority": "critical",
      "rules": [
        {
          "id": "ICON-REACT-01",
          "name": "React Icons Only",
          "library": "react-icons",
          "centralFile": "src/designSystem/icons/index.ts",
          "forbidden": [
            "Inline SVG (ESLint: no-inline-svg/no-inline-svg)",
            "Direct imports from react-icons in feature code",
            "Static SVG files"
          ],
          "severity": "blocking"
        },
        {
          "id": "ICON-THEME-02",
          "name": "Icon Theming",
          "description": "All icons must use theme context",
          "usage": {
            "import": "import { Icons } from '@/designSystem/icons';",
            "theming": "const { getIconClassName } = useTheme();",
            "render": "<Icons.like className={getIconClassName({ tone: 'accent', size: 'md' })} />"
          },
          "forbidden": [
            "Hardcoded icon colors",
            "Direct className without theme helper"
          ]
        },
        {
          "id": "ICON-NAMING-03",
          "name": "Semantic Icon Names",
          "description": "Use semantic names, not technical ones",
          "examples": {
            "good": "Icons.like, Icons.comment, Icons.premium, Icons.verified",
            "bad": "Icons.FaHeart, Icons.icon1, Icons.svg123"
          }
        }
      ],
      "security": {
        "category": "Security and Privacy",
        "priority": "critical",
        "rules": [
          {
            "id": "SEC-PRIVATE-01",
            "name": "Private by Default",
            "description": "All data and APIs are private unless specified otherwise",
            "guidelines": [
              "No sensitive data in client logs",
              "APIs must implement auth/authz by default",
              "Assume locked down, not permissive"
            ]
          },
          {
            "id": "SEC-STORAGE-02",
            "name": "Local Storage Policy",
            "description": "Use storageManager.ts only",
            "forbidden": [
              "Direct localStorage API calls",
              "Storing raw PII without encryption",
              "Permanent storage of sensitive tokens"
            ],
            "correct": {
              "import": "import { loadFromStorage, saveToStorage } from '@/utils/storageManager';",
              "usage": "loadFromStorage('key', { defaultValue: {}, migration: migrateData })"
            },
            "features": [
              "Automatic versioning",
              "Migration support",
              "Type safety"
            ]
          },
          {
            "id": "SEC-SECRETS-03",
            "name": "No Hardcoded Secrets",
            "description": "Hardcoded secrets in code are forbidden",
            "forbidden": [
              "API keys in code",
              "Passwords in config",
              "Tokens in constants"
            ],
            "correct": [
              "process.env.GEMINI_API_KEY",
              "process.env.OPENROUTER_API_KEY"
            ],
            "management": "Use environment variables or secure vault",
            "severity": "blocking"
          },
          {
            "id": "SEC-API-04",
            "name": "External API Access Control",
            "description": "All external calls must be in allow-list",
            "requirements": [
              "Whitelist all third-party APIs",
              "Log and audit all calls",
              "Implement rate limiting"
            ]
          },
          {
            "id": "SEC-LINKS-05",
            "name": "Signed Links & Expiry",
            "description": "All links must be signed and temporary",
            "requirements": [
              "TTL (time-to-live) for all file access links",
              "Default expiry: 15 minutes",
              "Revocation capability"
            ]
          }
        ]
      },
      "errorHandling": {
        "category": "Error Handling",
        "priority": "high",
        "rules": [
          {
            "id": "ERR-BOUNDARY-01",
            "name": "Global Error Boundary",
            "description": "The entire app must be wrapped in Error Boundary",
            "implementation": {
              "component": "components/ErrorBoundary.tsx",
              "usage": "Wrap entire app in App.tsx"
            },
            "purpose": "Prevent blank screen on component errors"
          },
          {
            "id": "ERR-API-02",
            "name": "API Error Handling",
            "description": "All data fetching must handle isError state",
            "guidelines": [
              "Always handle isError from React Query",
              "Display user-friendly messages",
              "Never show technical error details to users",
              "Log errors for debugging"
            ],
            "example": "if (isError) return <ErrorMessage message='Failed to load data' />;"
          },
          {
            "id": "ERR-FORMS-03",
            "name": "Form Validation & Feedback",
            "description": "All forms must provide field-level validation",
            "tools": [
              "Zod for schema validation",
              "react-hook-form for error display"
            ],
            "forbidden": "Single alert() for all form errors",
            "requirements": [
              "Show error under each invalid field",
              "Clear validation messages in English",
              "Validate on blur and submit"
            ]
          }
        ]
      },
      "testing": {
        "category": "Tests",
        "priority": "high",
        "rules": [
          {
            "id": "TEST-COVERAGE-01",
            "name": "Coverage Threshold",
            "minimum": "80% line coverage",
            "action": "PRs that decrease coverage will be blocked",
            "philosophy": "Untested code is broken code"
          },
          {
            "id": "TEST-UNIT-02",
            "name": "Unit Test Mandate",
            "description": "All business logic must be tested",
            "scope": [
              "Utility functions",
              "Custom hooks",
              "State store actions",
              "Pure functions"
            ],
            "tool": "Vitest",
            "guidelines": [
              "Test with various inputs",
              "Include edge cases",
              "Use @testing-library/react-hooks for hooks"
            ]
          },
          {
            "id": "TEST-COMPONENT-03",
            "name": "Component Testing",
            "description": "All UI components must be tested",
            "tool": "React Testing Library + Vitest",
            "guidelines": [
              "Test user perspective, not implementation",
              "Test rendering with different props",
              "Test user events (clicks, input)",
              "Test different states (loading, error, empty)",
              "Use msw for API mocking"
            ],
            "customRender": "Always use render from src/test/test-utils.tsx"
          },
          {
            "id": "TEST-E2E-04",
            "name": "End-to-End Testing",
            "description": "Critical flows must be tested end-to-end",
            "tool": "Playwright or Cypress",
            "criticalFlows": [
              "User authentication (Sign up, Log in, Log out)",
              "Search and filter on Discover page",
              "Submitting collaboration request",
              "Post creation and publishing"
            ]
          },
          {
            "id": "TEST-COMMANDS-05",
            "name": "Testing Commands",
            "commands": {
              "watch": "npm run test",
              "ui": "npm run test:ui",
              "coverage": "npm run test:coverage",
              "ci": "npm run test:run"
            }
          }
        ]
      },
      "stateManagement": {
        "category": "State Management",
        "priority": "high",
        "rules": [
          {
            "id": "STATE-CONTEXT-01",
            "name": "Context Pattern",
            "description": "Use Context API as primary pattern",
            "providers": [
              "ProfileContext",
              "FavoritesContext",
              "PostsContext",
              "InteractionsContext",
              "CommentsContext",
              "CollectionsContext",
              "ConnectionsContext",
              "SubscriptionsContext"
            ],
            "layering": "App.tsx wraps all 8 providers in order",
            "note": "Zustand installed but Context is primary"
          },
          {
            "id": "STATE-HOOKS-02",
            "name": "Context Hooks",
            "description": "Each Context exports a custom hook",
            "examples": [
              "usePosts()",
              "useProfile()",
              "useComments()",
              "useInteractions()"
            ],
            "usage": "Always use hook, never consume Context directly"
          },
          {
            "id": "STATE-IMMUTABLE-03",
            "name": "Immutability",
            "description": "All state updates must be immutable",
            "tools": [
              "useMemo for expensive computations",
              "useCallback for function memoization",
              "Immer for complex state updates"
            ],
            "forbidden": "Direct mutation of state objects"
          },
          {
            "id": "STATE-STORAGE-04",
            "name": "Storage Integration",
            "description": "All Contexts use storageManager",
            "functions": [
              "loadFromStorage() for initialization",
              "saveToStorage() for persistence"
            ],
            "features": [
              "Automatic versioning",
              "Migration support",
              "Type safety"
            ]
          }
        ]
      },
      "pathResolution": {
        "category": "Import Paths",
        "priority": "medium",
        "rules": [
          {
            "id": "PATH-ALIAS-01",
            "name": "Use @ Alias",
            "description": "Use @ to refer to src folder",
            "config": {
              "tsconfig": "\"@\": \"./src\"",
              "vite": "alias configured"
            },
            "examples": {
              "good": [
                "import Header from '@/components/Header';",
                "import { usePosts } from '@/contexts/PostsContext';",
                "import { Icons } from '@/designSystem/icons';"
              ],
              "bad": [
                "import Header from '../../components/Header';",
                "import Header from '../../../components/Header';"
              ]
            }
          },
          {
            "id": "PATH-EXTENSIONS-02",
            "name": "No File Extensions",
            "description": "Do not add .tsx or .ts in imports",
            "reason": "TypeScript bundler resolution",
            "examples": {
              "good": "import Component from '@/components/Component';",
              "bad": "import Component from '@/components/Component.tsx';"
            }
          },
          {
            "id": "PATH-RELATIVE-03",
            "name": "Relative Paths for Siblings Only",
            "description": "Use relative paths for files in the same folder only",
            "examples": {
              "good": "import './styles.css'; import { helper } from './utils';",
              "bad": "import Component from '../../other-folder/Component';"
            }
          }
        ]
      },
      "performance": {
        "category": "Performance",
        "priority": "high",
        "rules": [
          {
            "id": "PERF-MEMO-01",
            "name": "Memoization",
            "description": "Use memoization for heavy operations",
            "tools": [
              "useMemo for expensive calculations",
              "useCallback for function props",
              "React.memo for components"
            ],
            "guidelines": [
              "Memoize only when profiling shows benefit",
              "Don't over-optimize prematurely"
            ]
          },
          {
            "id": "PERF-LAZY-02",
            "name": "Code Splitting",
            "description": "Use lazy loading for large pages and components",
            "usage": "React.lazy() + Suspense",
            "targets": [
              "Route-level components",
              "Large feature modules",
              "Heavy third-party libraries"
            ]
          },
          {
            "id": "PERF-BUNDLE-03",
            "name": "Bundle Size",
            "description": "Monitor bundle size",
            "limits": {
              "initial": "< 200KB gzipped",
              "lazy_chunks": "< 100KB gzipped"
            },
            "tools": [
              "Vite bundle analyzer",
              "Lighthouse audits"
            ]
          }
        ]
      },
      "accessibility": {
        "category": "Accessibility",
        "priority": "high",
        "rules": [
          {
            "id": "A11Y-SEMANTIC-01",
            "name": "Semantic HTML",
            "description": "Use HTML semantic elements",
            "examples": {
              "good": "<button>, <nav>, <article>, <section>, <header>",
              "bad": "<div onClick>, <div role='button'>"
            }
          },
          {
            "id": "A11Y-ARIA-02",
            "name": "ARIA Labels",
            "description": "Add ARIA labels for interactive elements",
            "requirements": [
              "aria-label for icon-only buttons",
              "aria-labelledby for form sections",
              "aria-describedby for error messages"
            ]
          },
          {
            "id": "A11Y-KEYBOARD-03",
            "name": "Keyboard Navigation",
            "description": "All interactive elements must work with keyboard",
            "requirements": [
              "Tab order is logical",
              "Enter/Space activate buttons",
              "Escape closes modals",
              "Arrow keys navigate lists"
            ]
          },
          {
            "id": "A11Y-CONTRAST-04",
            "name": "Color Contrast",
            "description": "Contrast ratio must be WCAG AA compliant",
            "requirements": {
              "normal_text": "4.5:1 minimum",
              "large_text": "3:1 minimum"
            }
          }
        ]
      },
      "typeSystem": {
        "category": "Type System",
        "priority": "high",
        "rules": [
          {
            "id": "TYPE-SSOT-01",
            "name": "Single Source of Truth",
            "description": "All types in types.ts",
            "location": "src/types.ts",
            "forbidden": "Duplicate type definitions across files",
            "includes": [
              "Domain types (User, Post, Comment)",
              "UI types (Theme, Modal)",
              "API types (Request, Response)",
              "D3 graph types (InfluenceMap)"
            ]
          },
          {
            "id": "TYPE-STRICT-02",
            "name": "Strict Mode",
            "description": "TypeScript strict mode enabled",
            "config": "tsconfig.json: \"strict\": true",
            "forbidden": [
              "any type (use unknown instead)",
              "// @ts-ignore comments",
              "Type assertions without validation"
            ]
          },
          {
            "id": "TYPE-IMPORT-03",
            "name": "Type Imports",
            "description": "Use type imports for types only",
            "syntax": "import type { User, Post } from '@/types';",
            "reason": "Better tree-shaking and clear intent"
          }
        ]
      },
      "api": {
        "category": "APIs",
        "priority": "medium",
        "rules": [
          {
            "id": "API-ENDPOINTS-01",
            "name": "API Endpoints",
            "description": "Endpoints specified in vite.config.ts",
            "endpoints": [
              "/api/ai/chat - OpenRouter with Claude 3.5 Sonnet",
              "/api/ai/stream - Streaming responses"
            ],
            "implementation": "Express middleware in server/api.ts"
          },
          {
            "id": "API-ENV-02",
            "name": "Environment Variables",
            "description": "Use process.env for environment variables",
            "variables": [
              "process.env.GEMINI_API_KEY",
              "process.env.OPENROUTER_API_KEY",
              "process.env.OPENROUTER_BASE_URL"
            ],
            "injection": "vite.config.ts define object",
            "forbidden": "import.meta.env for these vars"
          },
          {
            "id": "API-ERROR-03",
            "name": "API Error Handling",
            "description": "All API calls must handle errors",
            "requirements": [
              "Try-catch blocks",
              "User-friendly error messages",
              "Logging for debugging",
              "Retry logic for transient failures"
            ]
          }
        ]
      },
      "documentation": {
        "category": "Documentation",
        "priority": "medium",
        "rules": [
          {
            "id": "DOC-COMMENTS-01",
            "name": "Code Comments",
            "description": "Write clear comments for complex code",
            "when": [
              "Complex algorithms",
              "Non-obvious business logic",
