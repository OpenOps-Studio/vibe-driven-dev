{
  "rule_name": "Global Motion & Animation System",
  "rule_code": "{{PROJECT_NAME}}-MOTION-SYSTEM-001",
  "objective": "Unify all animations, transitions, and motion behaviors across {{PROJECT_NAME}} to ensure consistent, elegant, and performance-safe user interactions.",

  "philosophy": {
    "keywords": ["Calm", "Fluid", "Purposeful", "Responsive"],
    "description": "Animations in {{PROJECT_NAME}} should feel natural, lightweight, and meaningful. Every motion must guide the user’s attention, never distract.",
    "avoid": ["Excessive bounce", "High-speed blurs", "Flashy transitions"]
  },

  "animation_system": {
    "library": "Framer Motion",
    "default_easing": "cubic-bezier(0.22, 1, 0.36, 1)",
    "timing_scale": {
      "micro": "100ms",
      "short": "180ms",
      "medium": "300ms",
      "long": "500ms",
      "xlong": "800ms"
    },
    "motion_tokens": {
      "fade_in": { "opacity": [0, 1], "duration": "medium" },
      "fade_out": { "opacity": [1, 0], "duration": "short" },
      "slide_up": { "y": [40, 0], "opacity": [0, 1], "duration": "medium" },
      "slide_down": { "y": [-30, 0], "opacity": [0, 1], "duration": "medium" },
      "scale_in": { "scale": [0.95, 1], "opacity": [0, 1], "duration": "medium" },
      "scale_out": { "scale": [1, 0.9], "opacity": [1, 0], "duration": "short" },
      "hover_lift": { "scale": [1, 1.03], "duration": "micro" },
      "press_tap": { "scale": [1, 0.97], "duration": "micro" }
    }
  },

  "motion_contexts": {
    "modals": {
      "entry": "scale_in",
      "exit": "fade_out",
      "backdrop": { "opacity": [0, 0.6], "duration": "medium" }
    },
    "cards": {
      "hover": "hover_lift",
      "entry": "fade_in",
      "exit": "fade_out",
      "shadow_transition": "box-shadow 0.2s ease-in-out"
    },
    "buttons": {
      "hover": "scale_in",
      "press": "press_tap",
      "focus": "glow (drop-shadow: 0 0 6px rgba(227,52,139,0.6))"
    },
    "lists": {
      "item_entry": "slide_up",
      "item_exit": "fade_out",
      "stagger": "50ms between children"
    },
    "tooltips": {
      "entry": "slide_up",
      "exit": "fade_out",
      "delay": "120ms"
    },
    "dropdowns": {
      "entry": "scale_in",
      "exit": "fade_out",
      "origin": "top-right"
    },
    "alerts": {
      "entry": "slide_down",
      "exit": "fade_out"
    }
  },

  "motion_safety": {
    "reduced_motion_support": true,
    "accessibility_setting": "prefers-reduced-motion",
    "fallback_behavior": {
      "if_user_prefers_reduced_motion": "disable transform and opacity animations, use instant transitions instead"
    },
    "fps_limit": 60,
    "gpu_acceleration": true
  },

  "responsive_behavior": {
    "mobile": {
      "reduce_motion_intensity": "15%",
      "prefer_slide_over_fade": true
    },
    "desktop": {
      "enable_staggered_lists": true,
      "add_depth_effect": true
    },
    "large_screens": {
      "use_parallax_backgrounds": true,
      "expand_modal_animations": "scale_in + fade"
    }
  },

  "performance": {
    "gpu_hint": "translate3d(0,0,0)",
    "motion_batching": "group small transitions together for low layout cost",
    "avoid": ["box-shadow animations", "layout-affecting transforms"]
  },

  "testing_and_validation": {
    "tools": ["Framer Motion DevTools", "React Profiler", "Lighthouse"],
    "rules": [
      "Animation duration must be between 100ms and 800ms",
      "No infinite animations in production",
      "No layout shifts greater than 5% of viewport height"
    ]
  },

  "implementation_examples": {
    "react_component_usage": {
      "example_fade_slide": "motion.div initial={{opacity:0,y:20}} animate={{opacity:1,y:0}} transition={{duration:0.3,ease:'easeOut'}}",
      "example_hover_card": "motion.div whileHover={{scale:1.03}} whileTap={{scale:0.97}}"
    },
    "hook": {
      "useMotionSettings": "returns userMotionPreference, currentDevice, recommendedDuration"
    }
  },

  "global_variables": {
    "--motion-duration-micro": "100ms",
    "--motion-duration-short": "180ms",
    "--motion-duration-medium": "300ms",
    "--motion-duration-long": "500ms",
    "--motion-duration-xlong": "800ms",
    "--motion-ease-default": "cubic-bezier(0.22,1,0.36,1)"
  },

  "documentation": {
    "file": "/docs/design-system/global-motion-rules.md",
    "sections": [
      "Philosophy of Motion in {{PROJECT_NAME}}",
      "Timing and Easing Tokens",
      "Component Motion Matrix",
      "Accessibility and Reduced Motion",
      "Performance Optimization"
    ]
  },

  "commit_message_standard": "chore(ui): enforce global motion and animation rules for consistent and fluid UX",
  "status": "active_enforcement",
  "enforcement_start_date": "2025-10-20"
}